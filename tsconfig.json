{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "config": ["src/config"],
      "infra/*": ["src/infra/*"],
      "core/*": ["src/core/*"],
      "utils/*": ["src/utils/*"],
      "agents/*": ["src/agents/*"],
      "tools/*": ["src/tools/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*", "scenarios/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
