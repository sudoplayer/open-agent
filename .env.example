# Copy this file to .env and fill values for local development.

# ── LLM ──────────────────────────────────────────────
MODEL_NAME="deepseek-v4-flash"
MODEL_BASE_URL="https://api.deepseek.com"
LLM_API_KEY="LLM_API_KEY"

# ── Server ───────────────────────────────────────────
# API port (defaults to 8888)
# API_PORT=8888

# ── Local debug (markdown preview without OpenWebUI) ─
# Mirror SSE output to debug/{sessionId}.md (async append). Off by default.
# DEBUG_STREAM=1
# DEBUG_STREAM_DIR=debug

# ── Workflow checkpoints ─────────────────────────────
# CHECKPOINT_DB_PATH=data/checkpoints.sqlite
# CHECKPOINT_RETENTION_DAYS=7
# CHECKPOINT_VACUUM_INTERVAL_HOURS=6